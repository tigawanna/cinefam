{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cinefam-web",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.tsx",
  "observability": {
    "enabled": true
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "00000000-0000-0000-0000-000000000004",
      "localConnectionString": "postgresql://postgres:postgres@localhost:5432/cinefam"
    }
  ]
}
