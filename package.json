{
  "name": "cinefam",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix .",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "check-types": "turbo run check-types",
    "quality": "turbo run //#lint //#format",
    "quality:fix": "turbo run //#lint:fix //#format:fix",
    "prepare": "vp config",
    "deploy:web": "pnpm --filter web deploy",
    "build-dev:local": "pnpm --filter mobile build-dev:local",
    "build:preview": "pnpm --filter mobile build:preview",
    "build:preview:local": "pnpm --filter mobile build:preview:local",
    "build:preview:arm64:local": "pnpm --filter mobile build:preview:arm64:local",
    "build:preview:eas": "pnpm --filter mobile build:preview:eas",
    "build:production:local": "pnpm --filter mobile build:production:local",
    "build:store": "pnpm --filter mobile build:store",
    "submit:store": "pnpm --filter mobile submit:store",
    "sync:icons": "tsx ./scripts/sync-expo-icons.ts"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260519.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "6.0.3",
    "vite-plus": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.12",
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.20"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ],
      "allowedVersions": {
        "vite": "*",
        "vitest": "*"
      }
    }
  }
}
