{
  "source": "./expo-icons",
  "expo": {
    "icon": "./icon.png",
    "splash": {
      "image": "./splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0a18",
      "imageWidth": 200
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      }
    },
    "web": {
      "favicon": "./favicon.png"
    }
  },
  "mobile": {
    "root": "./apps/mobile",
    "files": {
      "icon": "assets/icons/icon.png",
      "adaptiveIcon": "assets/icons/adaptive-icon.png",
      "splashIcon": "assets/icons/splash-icon.png",
      "favicon": "assets/icons/favicon.png"
    }
  },
  "web": {
    "root": "./apps/web",
    "files": {
      "favicon": "public/favicon.png",
      "appleTouchIcon": "public/apple-touch-icon.png"
    }
  },
  "sync": {
    "mobile": [
      { "from": "expo.icon", "to": "icon" },
      { "from": "expo.android.adaptiveIcon.foregroundImage", "to": "adaptiveIcon" },
      { "from": "expo.splash.image", "to": "splashIcon" },
      { "from": "expo.web.favicon", "to": "favicon" }
    ],
    "web": [
      { "from": "expo.web.favicon", "to": "favicon" },
      { "from": "expo.icon", "to": "appleTouchIcon" }
    ]
  }
}
